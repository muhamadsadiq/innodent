# Environment Variables Example
# Copy to .env.local for development, and to .env.production on VPS.

# ===== Site Configuration =====
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=InnoDent
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ===== Database Configuration (SQLite) =====
# Local development:
DATABASE_URL="file:./prisma/dev.db"
# VPS production (absolute path recommended):
# DATABASE_URL="file:/var/www/innodent-ai/prisma/prod.db"

# ===== Authentication =====
# Use a long random value in production (32+ chars)
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRATION=1d
REVALIDATE_SECRET=replace_with_a_second_strong_random_secret

# ===== Runtime Behavior =====
NODE_ENV=production
SEED_ON_BOOT=false

# ===== Optional Integrations =====
# STRIPE_SECRET_KEY=sk_test_...
# SENDGRID_API_KEY=SG...

# Optional: absolute persistent uploads directory for production/VPS
# UPLOADS_DIR="/var/www/uploads"
# Hero slider images will be stored in: /var/www/uploads/slider
# Catalog PDFs will be stored in: /var/www/uploads/catalogs
